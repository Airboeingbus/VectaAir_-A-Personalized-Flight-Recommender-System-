# Flask Configuration
FLASK_DEBUG=False
FLASK_SECRET_KEY=your-generated-secret-key-here-min-32-chars-recommended

# Server Configuration
PORT=5000

# Data Configuration
DATA_PATH=data/processed

# Logging
LOG_LEVEL=INFO

# ========================================
# PRODUCTION SETUP INSTRUCTIONS:
# ========================================
# 1. Generate a secure secret key:
#    python -c "import secrets; print(secrets.token_hex(32))"
#
# 2. Replace FLASK_SECRET_KEY with the generated value
#
# 3. Set FLASK_DEBUG=False for production
#
# 4. Deploy with: gunicorn -w 4 -b 0.0.0.0:$PORT app:app
# ========================================
